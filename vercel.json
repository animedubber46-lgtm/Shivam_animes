{
  "version": 2,
  "installCommand": "pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm --filter @workspace/api-spec run codegen && BASE_PATH=/ PORT=3000 pnpm --filter @workspace/shivam-animes run build",
  "outputDirectory": "artifacts/shivam-animes/dist",
  "framework": null,
  "functions": {
    "api/index.ts": {
      "runtime": "nodejs22.x",
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
